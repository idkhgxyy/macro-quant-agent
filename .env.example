# =============================================================================
# Macro Quant Agent — 环境变量配置示例
# 复制本文件为 .env 后填入实际值:
#   cp .env.example .env
# =============================================================================

# ===== LLM 配置 =====
# API 密钥和模型选择
ALPHA_VANTAGE_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
VOLCENGINE_API_KEY=
VOLCENGINE_MODEL_ENDPOINT=
LLM_BASE_URL=
LLM_PROVIDER=
LLM_THINKING_TYPE=enabled
LLM_REASONING_EFFORT=high

# ===== Broker 配置 =====
# mock: 模拟券商（默认，无真实资金风险）
# ibkr: Interactive Brokers 真实/仿真交易
BROKER_TYPE=mock
ENABLE_LIVE_TRADING=false

# ===== IBKR 配置（仅 BROKER_TYPE=ibkr 时需要）=====
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1
IBKR_DATA_CLIENT_ID=11

# ===== 市场时段 =====
MARKET_TIMEZONE=America/New_York
ENFORCE_RTH=true
RTH_START=09:30
RTH_END=16:00
HALF_DAY_RTH_END=13:00
ALLOW_OUTSIDE_RTH=false

# ===== 告警通知 =====
ALERT_WEBHOOK_URL=
ALERT_COOLDOWN_SECONDS=1800
ALERT_DATA_FAILED_THRESHOLD=3
ALERT_LLM_INVALID_THRESHOLD=2
ALERT_ORDER_PROBLEM_THRESHOLD=3
ALERT_EXCEPTION_THRESHOLD=1
ALERT_AUTO_KILL_SWITCH=true
ALERT_WEBHOOK_INCLUDE_RECENT=true
ALERT_WEBHOOK_RECENT_LIMIT=15

# ===== 调度器 =====
AGENT_SCHEDULER_ENABLED=false
AGENT_SCHEDULE_TIME=16:10
AGENT_SCHEDULE_TIMEZONE=America/New_York
AGENT_SCHEDULE_POLL_SECONDS=30
AGENT_RUN_LOCK_STALE_SECONDS=21600

# ===== 风控 =====
AUTO_LIQUIDATE_DUST=false
DUST_MAX_WEIGHT=0.01

# ===== 数据源 =====
SEC_EDGAR_USER_AGENT=isolation-research/0.1 contact@example.com

# ===== 运行时路径（通常由代码自动决定）=====
# RUNTIME_STATE_DIR=./runtime
# HEARTBEAT_STATE_PATH=./runtime/heartbeat.json
# KILL_SWITCH_STATE_PATH=./runtime/kill_switch.json
