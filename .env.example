# =============================================================================
# Macro Quant Agent — 环境变量配置示例
# 复制本文件为 .env 后填入实际值:
#   cp .env.example .env
# =============================================================================

# ===== LLM 配置 =====
# 必须至少配置一组 LLM 提供商，否则策略生成无法运行。
#
# 方案 A：火山引擎（推荐国内用户）
#   申请地址：https://console.volcengine.com/ark
#   创建推理接入点后获取 endpoint
ALPHA_VANTAGE_KEY=                          # Alpha Vantage API Key（用于宏观数据检索，非必填但推荐）
VOLCENGINE_API_KEY=                         # 火山引擎 API Key
VOLCENGINE_MODEL_ENDPOINT=                  # 火山引擎模型端点，格式如 ep-xxxxxxxx-xxxxx
#
# 方案 B：DeepSeek（推荐海外用户）
#   申请地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY=                           # DeepSeek API Key（若未设 VOLCENGINE_API_KEY，系统会 fallback 到此值）
DEEPSEEK_MODEL=deepseek-chat                # DeepSeek 模型名称
#
# 以下三项通常无需手动设置，系统会根据上方 Key 自动推断：
# LLM_BASE_URL=                             # 自定义 LLM API 地址（覆盖自动推断）
# LLM_PROVIDER=                             # volcengine 或 deepseek（覆盖自动推断）
LLM_THINKING_TYPE=enabled                   # LLM 思考模式：enabled / disabled
LLM_REASONING_EFFORT=high                   # 推理深度：low / medium / high

# ===== Broker 配置 =====
# mock:  模拟券商（默认，无真实资金风险，本地计算模拟成交）
# ibkr:  Interactive Brokers 真实/仿真交易（需本地运行 TWS 或 IB Gateway）
BROKER_TYPE=mock
ENABLE_LIVE_TRADING=false                   # 仅 BROKER_TYPE=ibkr 时生效；false = planning_only 模式，不提交真实订单

# ===== IBKR 配置（仅 BROKER_TYPE=ibkr 时需要）=====
IBKR_HOST=127.0.0.1                         # TWS / IB Gateway 地址
IBKR_PORT=7497                              # 7497=仿真, 7496=实盘
IBKR_CLIENT_ID=1                            # TWS 客户端 ID（每个连接需唯一）
IBKR_DATA_CLIENT_ID=11                      # 数据连接客户端 ID（自动设为 CLIENT_ID+10）

# ===== 市场时段 =====
MARKET_TIMEZONE=America/New_York            # 市场时区
ENFORCE_RTH=true                            # 是否强制在常规交易时段内下单
RTH_START=09:30                             # 常规交易时段开始（美东时间）
RTH_END=16:00                               # 常规交易时段结束（美东时间）
HALF_DAY_RTH_END=13:00                      # 半天交易日结束时间
ALLOW_OUTSIDE_RTH=false                     # 是否允许盘前盘后下单

# ===== 告警通知 =====
# 配置 webhook 后，系统会在异常时发送通知；留空则不发送。
ALERT_WEBHOOK_URL=                          # 通知 webhook 地址，如 https://hooks.example.com/xxx
ALERT_COOLDOWN_SECONDS=1800                 # 同类告警冷却时间（秒）
ALERT_DATA_FAILED_THRESHOLD=3               # 数据源连续失败 N 次触发告警
ALERT_LLM_INVALID_THRESHOLD=2               # LLM 连续无效 N 次触发告警
ALERT_ORDER_PROBLEM_THRESHOLD=3             # 订单异常 N 次触发告警
ALERT_EXCEPTION_THRESHOLD=1                 # 未捕获异常 N 次触发告警
ALERT_AUTO_KILL_SWITCH=true                 # 告警是否自动触发熔断
ALERT_WEBHOOK_INCLUDE_RECENT=true           # webhook 是否包含最近事件
ALERT_WEBHOOK_RECENT_LIMIT=15               # webhook 包含最近事件条数

# ===== 调度器 =====
AGENT_SCHEDULER_ENABLED=false               # 启用后 run_scheduler.py 会按计划自动触发每日运行
AGENT_SCHEDULE_TIME=16:10                   # 每日触发时间（美东时间 HH:MM）
AGENT_SCHEDULE_TIMEZONE=America/New_York    # 调度时区
AGENT_SCHEDULE_POLL_SECONDS=30              # 调度器轮询间隔（秒）
AGENT_RUN_LOCK_STALE_SECONDS=21600          # 运行锁过期时间（秒，默认 6 小时）

# ===== 风控 =====
AUTO_LIQUIDATE_DUST=false                   # 是否自动清仓微小持仓
DUST_MAX_WEIGHT=0.01                        # 微小持仓阈值（权重低于此值视为 dust）

# ===== 数据源 =====
# FMP (Financial Modeling Prep): 美股主数据源，免费版 250 次/天，覆盖 OHLCV + 基本面 + 新闻 + 宏观
#   申请地址：https://site.financialmodelingprep.com/register
FMP_API_KEY=                                # FMP API Key（推荐，替代 Alpha Vantage 作为主源）
# Alpha Vantage: 备用数据源，免费版 25 次/天
ALPHA_VANTAGE_KEY=                          # Alpha Vantage API Key（非必填，FMP 优先）
# AnySearch: 财经垂直搜索引擎，提供高质量新闻和宏观数据（可选，匿名可用）
#   申请地址：https://anysearch.com/console/api-keys
#   不配置 API Key 也可使用（低限额），配置后获得更高限额
ANYSEARCH_API_KEY=                            # AnySearch API Key（可选）
SEC_EDGAR_USER_AGENT=isolation-research/0.1 contact@example.com  # SEC EDGAR 爬虫 User-Agent（合规要求）

# ===== 运行时路径（通常由代码自动决定，无需修改）=====
# RUNTIME_STATE_DIR=./runtime
# HEARTBEAT_STATE_PATH=./runtime/heartbeat.json
# KILL_SWITCH_STATE_PATH=./runtime/kill_switch.json
